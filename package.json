{
  "name": "maven-warning-gha",
  "version": "1.0.0",
  "description": "GitHub Action to parse Maven compiler warnings and post inline PR review comments",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
